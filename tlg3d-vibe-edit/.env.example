
# ===== MESSAGING PLATFORMS =====
# ── Discord ────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=
DISCORD_SECRET=

# ── Telegram ───────────────────────────────────────────────────
TELEGRAM_TOKEN=

# ── WhatsApp (Meta Cloud API — no Twilio needed) ──────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=cutflow_whatsapp_verify

# ── SMS / RCS (Native OS — no Twilio) ─────────────────────────
# Set to true to enable native SMS on this machine
SMS_ENABLED=false
# macOS: uses Messages.app via osascript (no config needed)
# Linux: install gammu — sudo apt install gammu
# Windows: uses Windows.Devices.Sms PowerShell API

# ── iMessage (macOS only — no config needed) ──────────────────
# Requires Full Disk Access for CutFlow in System Preferences
IMESSAGE_ENABLED=false

# ── Slack ──────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
SLACK_PORT=3002

# ── Signal (signal-cli — no API key needed) ───────────────────
# Install signal-cli and register your number first:
# signal-cli -u +1XXXXXXXXXX register
SIGNAL_PHONE_NUMBER=

# ── Email (SMTP + IMAP — works with any mail provider) ────────
EMAIL_USER=
EMAIL_PASS=
# Leave blank to auto-detect from email domain
SMTP_HOST=
SMTP_PORT=587
IMAP_HOST=
IMAP_PORT=993
# Supported: Gmail, Outlook, Yahoo, iCloud, ProtonMail (via Bridge), custom

# ── Instagram DM (Meta API) ────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_VERIFY_TOKEN=cutflow_ig_verify
INSTAGRAM_PAGE_ID=

# ── Facebook Messenger (Meta API) ─────────────────────────────
MESSENGER_PAGE_TOKEN=
MESSENGER_VERIFY_TOKEN=cutflow_messenger_verify
MESSENGER_PAGE_ID=

# ── X / Twitter DM (X API v2) ─────────────────────────────────
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BOT_USER_ID=

# ── LINE Messaging API ─────────────────────────────────────────
LINE_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ── Viber Bot API ──────────────────────────────────────────────
VIBER_AUTH_TOKEN=

# ── WeChat Official Account API ───────────────────────────────
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=cutflow_wechat

# ── Messaging Service Port ─────────────────────────────────────
MESSAGING_PORT=3003
# Base URL for webhook registration (must be publicly accessible)
WEBHOOK_BASE_URL=https://your-server.cutflow.dev

# ===== LLM PROVIDERS =====
OPENROUTER_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
CEREBRAS_API_KEY=
COHERE_API_KEY=
SAMBA_API_KEY=
HUGGINGFACE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
FIREWORKS_AI_API_KEY=
LONGCAT_API_KEY=
MINIMAX_API_KEY=
KIMI_MOONSHOT_API_KEY=
Z_AI_API_KEY=
STEPFUN_API_KEY=
DEEPINFRA_API_KEY=
MULEROUTER_API_KEY=

# ===== STORAGE & DATABASE =====
MONGODB_URI=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=

# ===== VOICE & AUDIO =====
ELEVENLABS_API_KEY=

# ===== SEARCH & WEB =====
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
FIRECRAWL_API_KEY=
EXA_API_KEY=

# ===== MEMORY & CONTEXT =====
MEM0_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
HONCHO_API_KEY=

# ===== AUTOMATION =====
COMPOSIO_API_KEY=
AGENTMAIL_API_KEY=

# ===== GITHUB =====
GITHUB_TOKEN=
GITHUB_REPO_OWNER=serthrocken
GITHUB_REPO_NAME=cutflow

# ===== VIDEO PROCESSING =====
FFMPEG_PATH=/usr/bin/ffmpeg
MAX_VIDEO_SIZE_MB=5000
SUPPORTED_FORMATS=mp4,mov,mkv,webm,avi

# ===== LLM ROUTING & LOCAL MODELS =====
LLM_PRIMARY_PROVIDER=openrouter
LLM_FALLBACK_PROVIDER=local
OLLAMA_ENABLED=true
OLLAMA_MODELS=mistral:7b-instruct-q4_K_M,phi:2-q4_K_M,llama2:13b-chat-q4_K_M
OLLAMA_GPU_LAYERS=-1
LLM_SCRIPT_GENERATOR=local
LLM_VOICEOVER_GENERATOR=openrouter
LLM_SCENE_ANALYZER=local
SYSTEM_GPU_VRAM=12
SYSTEM_CPU_GENERATION=i7-9700K
SYSTEM_RAM_AVAILABLE=32

# ===== APPLICATION =====
NODE_ENV=development
PORT=3000
APP_NAME=CutFlow
COMPANY_NAME=The Looking Glass 3D
LOG_LEVEL=debug

# ===== MARKETPLACE =====
SKILLS_DIR=./data/skills
INSTALLED_FILE=./data/installed_skills.json
MARKETPLACE_API_URL=https://marketplace.cutflow.dev/api

# ===== USER DATA =====
DATA_DIR=./data/users
TEMP_DIR=./tmp

# ===== MUSIC SEARCH APIs =====
# YouTube Data API v3 (optional — falls back to deep link without key)
YOUTUBE_API_KEY=

# Spotify (optional — get from https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Apple Music (optional — get from https://developer.apple.com/music)
APPLE_MUSIC_TOKEN=

# SoundCloud (optional — get from https://developers.soundcloud.com)
SOUNDCLOUD_CLIENT_ID=

# Tidal (optional — get from https://developer.tidal.com)
TIDAL_TOKEN=

# Amazon Music — deep link only, no API key needed

# yt-dlp (for YouTube audio download — install via: pip install yt-dlp)
# No API key needed — uses yt-dlp CLI