{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CutFlow",
  "identifier": "dev.tlg3d.cutflow",
  "version": "0.1.0",

  "build": {
    "beforeDevCommand":   "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl":    "http://localhost:5173",
    "frontendDist": "../dist"
  },

  "app": {
    "windows": [
      {
        "title":           "CutFlow",
        "label":           "main",
        "width":           1280,
        "height":          800,
        "minWidth":        900,
        "minHeight":       600,
        "resizable":       true,
        "fullscreen":      false,
        "decorations":     true,
        "transparent":     false,
        "center":          true,
        "visible":         true,
        "titleBarStyle":   "Overlay",
        "hiddenTitle":     true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost"
    },
    "withGlobalTauri": true
  },

  "bundle": {
    "active":      true,
    "targets":     "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],

    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm":       "sha256",
      "timestampUrl":          "",
      "wix": {
        "language": ["en-US"],
        "template":  null,
        "componentGroupRefs": [],
        "componentRefs":      [],
        "featureGroupRefs":   [],
        "featureRefs":        [],
        "mergeRefs":          []
      },
      "nsis": {
        "license":           null,
        "headerImage":       null,
        "sidebarImage":      null,
        "installerIcon":     null,
        "installMode":       "currentUser",
        "languages":         ["English"],
        "customLanguageFiles": null,
        "displayLanguageSelector": false
      }
    },

    "macOS": {
      "frameworks":           [],
      "minimumSystemVersion": "12.0",
      "exceptionDomain":      "",
      "signingIdentity":      null,
      "providerShortName":    null,
      "entitlements":         "entitlements.plist"
    },

    "linux": {
      "deb": {
        "depends": ["ffmpeg", "libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "appimage": {
        "bundleMediaFramework": true,
        "files": {}
      },
      "rpm": {
        "license":  "MIT",
        "depends":  ["ffmpeg"],
        "obsoletes": [],
        "provides": [],
        "conflicts": []
      }
    },

    "publisher":     "The Looking Glass 3D",
    "copyright":     "Copyright © 2024 The Looking Glass 3D. All rights reserved.",
    "category":      "Multimedia",
    "shortDescription": "AI-powered video editing",
    "longDescription":  "CutFlow is an agentic AI video editing platform with local model support, multi-platform messaging, and a skills marketplace.",
    "externalBin":   ["ffmpeg", "ffprobe"],
    "resources":     ["assets/*"]
  }
}
